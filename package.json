{
  "name": "wyst.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "wyst.dev project homepage and generated documentation site",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "audit": "node tools/audit-site.mjs",
    "audit:browser": "node tools/audit-browser.mjs",
    "audit:live": "node tools/audit-live-site.mjs",
    "build": "node build/generate.mjs && node build/generate-sitemap.mjs",
    "build:worker-assets": "node build/generate-404.mjs && node tools/prepare-worker-assets.mjs",
    "sync:brand": "node tools/sync-brand-assets.mjs",
    "deploy": "wrangler deploy",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "prismjs": "^1.29.0",
    "wrangler": "^4.102.0"
  }
}
