SEMIHOST_APPLICATION_EXIT :: u64 = 0x20026
semihost_exit_reason : u64 = SEMIHOST_APPLICATION_EXIT
semihost_exit_status : u64 = 1

#noreturn
test_exit :: (code : u64) {
  semihost_exit_status = code
  operation : u64 #pin(x0) = 0x18
  args : u64 #pin(x1) = #addr_of(semihost_exit_reason)
  %hlt(0xf000)

  loop {
    %wfe()
  }
}
