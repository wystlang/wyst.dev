#!/bin/sh
#
# Keep generated docs and the committed Worker deploy artifact in sync with
# their sources. See README "Cloudflare deployment".
#
# Activated via core.hooksPath (set by the package.json "prepare" script).
set -e

staged_paths=$(git diff --cached --name-only)

if printf '%s\n' "$staged_paths" | grep -Eq '^(package(-lock)?\.json|build/(generate|generate-sitemap|template|prism-wyst)\.mjs)$'; then
	echo "pre-commit: refreshing docs/ from source…"
	npm run --silent build
	git add docs sitemap.xml
fi

if printf '%s\n' "$staged_paths" | grep -Eq '^(package(-lock)?\.json|index\.html|404\.html|robots\.txt|sitemap\.xml|assets/|docs/|build/(generate|generate-sitemap|generate-404|template|prism-wyst)\.mjs|tools/prepare-worker-assets\.mjs)'; then
	echo "pre-commit: refreshing .worker-assets/ from source…"
	npm run --silent build:worker-assets
	git add 404.html sitemap.xml .worker-assets
fi
